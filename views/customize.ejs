<section class="customize">

<h2>Customize Your Gift</h2>

<form class="custom-form">

<label>Occasion</label>
<select>
<option>Birthday</option>
<option>Wedding</option>
<option>Anniversary</option>
<option>Baby Shower</option>
<option>Graduation</option>
<option>Corporate Event</option>
</select>

<label>Choose Bouquet</label>
<select>
<option>Rose Bouquet</option>
<option>Pastel Bouquet</option>
<option>Wedding Bouquet</option>
<option>Tulip Bouquet</option>
<option>Sunflower Bouquet</option>
<option>Luxury Mixed Bouquet</option>
</select>

<label>Wrapping Paper</label>
<select>
<option>Gold</option>
<option>Silver</option>
<option>Pink</option>
<option>Red</option>
<option>White</option>
<option>Blue</option>
</select>

<label>Add Chocolates</label>
<input type="checkbox"> Ferrero Rocher<br>
<input type="checkbox"> Dairy Milk Silk<br>
<input type="checkbox"> Lindt Chocolates

<br><br>

<label>Add Teddy Bear</label>
<input type="checkbox"> Yes

<br><br>

<label>Personal Message</label>

<textarea rows="5" placeholder="Write your message here..."></textarea>

<label>Delivery Date</label>

<input type="date">

<button type="submit">Place Order</button>

</form>

</section>
